{
  "matrix_version": 1,
  "artifact_schema": {
    "storage_path_pattern": ".opencode/state/artifacts/proof-<family>.json",
    "format": "json",
    "required_top_level_fields": [
      "family",
      "stack_label",
      "proof_tier",
      "passed",
      "checked_at",
      "artifact_path",
      "artifact_kind",
      "summary"
    ],
    "optional_top_level_fields": [
      "command",
      "exit_code",
      "url",
      "screenshot_path",
      "log_excerpt",
      "degraded_reason",
      "not_applicable_reason",
      "steps"
    ],
    "step_result_fields": {
      "required": [
        "step_id",
        "status",
        "summary",
        "artifact_kind",
        "artifact_path"
      ],
      "optional": [
        "degraded_reason",
        "not_applicable_reason",
        "tool_bundle",
        "url",
        "screenshot_path"
      ]
    }
  },
  "headless_degradation_order": [
    "process_health",
    "http_or_runtime_truth",
    "virtual_display_screenshot",
    "full_browser_or_device_interaction"
  ],
  "tool_bundles": {
    "runtime-command": {
      "title": "Runtime command and process proof",
      "tools": [
        "repo-native test/build command",
        "process exit status",
        "log capture"
      ],
      "validator_status": "implemented"
    },
    "structured-output": {
      "title": "Structured output comparison",
      "tools": [
        "JSON or text diff",
        "golden output check"
      ],
      "validator_status": "implemented"
    },
    "http-probe": {
      "title": "HTTP and network probe proof",
      "tools": [
        "curl",
        "Invoke-WebRequest",
        "repo-native health endpoint probe"
      ],
      "validator_status": "implemented"
    },
    "browser-automation": {
      "title": "Browser automation proof",
      "tools": [
        "Playwright",
        "headless browser screenshot"
      ],
      "validator_status": "implemented"
    },
    "desktop-visual": {
      "title": "Desktop launch and screenshot proof",
      "tools": [
        "ImageMagick",
        "ffmpeg",
        "virtual display screenshot"
      ],
      "validator_status": "implemented"
    },
    "game-visual": {
      "title": "Game boot, screenshot, and input smoke proof",
      "tools": [
        "Godot headless launch",
        "ImageMagick",
        "ffmpeg",
        "Vulkan or graphics capability check"
      ],
      "validator_status": "implemented"
    },
    "android-runtime": {
      "title": "Android build, emulator, and device proof",
      "tools": [
        "Gradle",
        "adb",
        "logcat",
        "Android emulator",
        "Android SDK CLI"
      ],
      "validator_status": "implemented"
    },
    "native-build": {
      "title": "Native desktop build proof",
      "tools": [
        "CMake",
        "compiler toolchain"
      ],
      "validator_status": "implemented"
    },
    "bootstrap-check": {
      "title": "Bootstrap and prerequisite proof",
      "tools": [
        "repo-native package manager",
        "toolchain presence check"
      ],
      "validator_status": "implemented"
    },
    "language-server-advice": {
      "title": "Language-server assistance",
      "tools": [
        "language server"
      ],
      "validator_status": "advisory_only"
    }
  },
  "primary_family_order": [
    "game",
    "web",
    "desktop",
    "android",
    "service",
    "cli-script"
  ],
  "families": {
    "cli-script": {
      "title": "CLI and script repos",
      "supplements_tier1_stack_proof": true,
      "activation": "repo_completion",
      "overlay_capable": false,
      "fallback": true,
      "match": {
        "stack_label_any": [
          "python",
          "rust",
          "go",
          "cli",
          "script",
          "c-cpp",
          "dotnet"
        ],
        "finish_any": [
          "cli",
          "script",
          "automation",
          "batch"
        ],
        "brief_any": [
          "command line",
          "script repo"
        ]
      },
      "stack_adapters": [
        "python",
        "rust",
        "go",
        "node",
        "c-cpp",
        "dotnet"
      ],
      "required_artifact_kinds": [
        "config-report",
        "command-output"
      ],
      "allowed_degradation_rules": [
        "Degraded proof is not allowed for CLI and script repos; record a blocking failure instead."
      ],
      "proof_tiers": [
        {
          "id": "static-contract",
          "label": "Static contract and config checks",
          "requirement": "required",
          "validator_status": "implemented",
          "artifact_kind": "config-report",
          "tool_bundles": [
            "bootstrap-check"
          ]
        },
        {
          "id": "build-or-bootstrap",
          "label": "Build, install, or bootstrap checks",
          "requirement": "required",
          "validator_status": "implemented",
          "artifact_kind": "command-output",
          "tool_bundles": [
            "runtime-command"
          ]
        },
        {
          "id": "command-runtime",
          "label": "Command exit and output truth",
          "requirement": "required",
          "validator_status": "implemented",
          "artifact_kind": "command-output",
          "tool_bundles": [
            "runtime-command",
            "structured-output"
          ]
        },
        {
          "id": "visual-review",
          "label": "Visual review",
          "requirement": "not_required",
          "validator_status": "not_required",
          "artifact_kind": "none",
          "tool_bundles": []
        }
      ]
    },
    "service": {
